rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /classAttendances/{attendanceId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /evaluations/{evaluationId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
